#!/usr/bin/env bash
set -euo pipefail

if (( $# != 0 )); then
  echo "ERROR: bin/ci accepts no arguments." >&2
  exit 64
fi

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$root"

# Keep native dependency builds hermetic when the host compiler is wrapped by ccache.
export CCACHE_DIR="${CCACHE_DIR:-$root/target/ccache}"
export CCACHE_TEMPDIR="${CCACHE_TEMPDIR:-$root/target/ccache-tmp}"
mkdir -p "$CCACHE_DIR" "$CCACHE_TEMPDIR"

if [[ ! -f Cargo.lock ]]; then
  echo "ERROR: Cargo.lock is required; generate and review it before running CI." >&2
  exit 66
fi

cargo fmt --all -- --check
cargo clippy --workspace --all-targets --all-features --locked -- -D warnings
cargo test --workspace --all-features --locked
cargo run --quiet --locked --bin rdashboard-schema -- --check config/schema/project-manifest-v1.json
cargo run --quiet --locked --bin rdashboard-schema -- --check config/schema/project-manifest-v2.json
bash -n \
  deploy/titanium/bootstrap-rust-v1 \
  deploy/titanium/bootstrap-rust-v2 \
  deploy/titanium/bootstrap-rust-common.bash \
  deploy/titanium/test-rust-v2-wrappers
for wrapper in deploy/titanium/wrappers/*; do
  sh -n "$wrapper"
done
for wrapper in deploy/titanium/wrappers-v2/*; do
  bash -n "$wrapper"
done
deploy/titanium/test-rust-v2-wrappers
node --check web/app.js
node --test tests/browser_status.test.js
release_inventory="$(
  cargo run --quiet --locked --bin rdashboard-self-release-inventory
)"
mapfile -t release_binaries <<<"$release_inventory"
if (( ${#release_binaries[@]} == 0 )); then
  echo "ERROR: the canonical self-release binary inventory is empty." >&2
  exit 70
fi
release_arguments=()
for binary in "${release_binaries[@]}"; do
  release_arguments+=(--bin "$binary")
done
cargo build --workspace --all-features --release --locked "${release_arguments[@]}"
cargo_target_dir="${CARGO_TARGET_DIR:-$root/target}"
cargo run --quiet --locked --bin rdashboard-self-release-inventory -- \
  --seal "$cargo_target_dir/release"
