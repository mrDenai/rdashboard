[Unit]
Description=rdashboard bounded rootless OCI BuildKit
After=local-fs.target
RequiresMountsFor=/var/lib/rdashboard-build

[Service]
Type=exec
User=rdashboard-buildkit
Group=rdashboard-build
ExecStart=/usr/libexec/rdashboard/rootlesskit --net=host --propagation=rslave /usr/libexec/rdashboard/buildkitd --config /etc/rdashboard/buildkitd.toml
RuntimeDirectory=rdashboard-buildkit
RuntimeDirectoryMode=0750
UMask=0007
Environment=HOME=/nonexistent
Environment=XDG_RUNTIME_DIR=/run/rdashboard-buildkit
Environment=PATH=/usr/libexec/rdashboard:/usr/bin
NoNewPrivileges=no
PrivateDevices=yes
PrivateNetwork=yes
PrivateTmp=yes
ProtectClock=yes
ProtectControlGroups=yes
ProtectHome=yes
ProtectHostname=yes
ProtectKernelLogs=yes
ProtectKernelModules=yes
ProtectKernelTunables=yes
# RootlessKit's setuid mapping helpers must inspect the just-created user namespace
# through /proc/<pid>; hidepid makes that process disappear before uid_map is written.
ProtectProc=default
ProcSubset=all
ProtectSystem=strict
ReadWritePaths=/var/lib/rdashboard-build/buildkit /run/rdashboard-buildkit
InaccessiblePaths=-/etc/rdashboard/credentials -/var/lib/rdashboard -/var/lib/rdashboard-executor -/var/lib/rdashboard-workflow-launcher -/run/rdashboard -/run/rdashboard-source-ingress -/run/rdashboard-source-delivery -/run/rdashboard-workflow -/run/rdashboard-workflow-launcher -/run/docker.sock -/var/run/docker.sock -/run/containerd -/run/podman/podman.sock
RestrictAddressFamilies=AF_UNIX AF_NETLINK
RestrictNamespaces=user mnt pid ipc uts net cgroup
RestrictRealtime=yes
LockPersonality=yes
SystemCallArchitectures=native
# The service starts without ambient host capabilities. Keep the bounding set intact
# so the fixed setuid mapping helpers and root inside the child user namespace can
# acquire the capabilities their namespace lifecycle requires.
CapabilityBoundingSet=~
AmbientCapabilities=
DevicePolicy=closed
Delegate=yes
TasksMax=1024
LimitNOFILE=4096
MemoryMax=6G
MemorySwapMax=0
CPUQuota=300%
IOWeight=50
TimeoutStartSec=15s
TimeoutStopSec=15s
Restart=on-failure
RestartSec=2s

[Install]
WantedBy=multi-user.target
