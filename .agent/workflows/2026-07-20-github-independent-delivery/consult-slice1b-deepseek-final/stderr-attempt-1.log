+fn read_start(
+    job_directory: &Path,
+    required_uid: u32,
+) -> Result<ExecutionStartEvidenceV1, ExecutionReceiptRuntimeError> {
+    let bytes = read_owner_only_file(&job_directory.join(EXECUTION_START_FILE_NAME), required_uid)?;
+    ExecutionStartEvidenceV1::decode_canonical(&bytes)
+}
